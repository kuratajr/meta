{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "lib": [
            "esnext",
            "webworker"
        ],
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "strict": true,
        "allowJs": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "types": [
            "@cloudflare/workers-types"
        ]
    },
    "include": [
        "src/**/*"
    ]
}